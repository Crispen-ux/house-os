# ============================================================
# House OS - Production Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# Password for the houseos_user PostgreSQL account
DB_PASSWORD=your_secure_database_password_here

# ------------------------------------------------------------
# Authentication
# ------------------------------------------------------------
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ------------------------------------------------------------
# Application URLs
# ------------------------------------------------------------
# Public URL where the web app is accessible
APP_URL=http://129.151.177.10:3000

# Public URL where the API is accessible (used by server-side code)
API_URL=http://129.151.177.10:4000

# CORS origin — must match the web app URL (used for direct API access)
CORS_ORIGIN=http://129.151.177.10:3000

# The web app proxies /api/* to the API via Next.js rewrites.
# The browser never talks to the API directly — no CORS/cookie issues.

# ------------------------------------------------------------
# Ports (host-side)
# ------------------------------------------------------------
API_PORT=4000
WEB_PORT=3000

# ------------------------------------------------------------
# AI / Ollama
# ------------------------------------------------------------
AI_PROVIDER=ollama
OLLAMA_MODEL=llama3

# Ollama URL is internal Docker network: http://ollama:11434
# No need to set this unless running outside Docker.

# ------------------------------------------------------------
# Email (SMTP) — optional
# ------------------------------------------------------------
# Required for sending invitation emails.
# Get free SMTP at https://mailtrap.io or use your own.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@houseos.app

# ------------------------------------------------------------
# Cookie Security
# ------------------------------------------------------------
# Set to "true" when behind HTTPS (e.g. with Caddy/nginx + TLS).
# Must be "false" for plain HTTP.
COOKIE_SECURE=false

# ------------------------------------------------------------
# OAuth — optional
# ------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common
