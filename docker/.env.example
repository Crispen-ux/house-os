# ============================================================
# House OS - Production Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ------------------------------------------------------------
# Database
# ------------------------------------------------------------
# Password for the houseos_user PostgreSQL account
DB_PASSWORD=your_secure_database_password_here

# ------------------------------------------------------------
# Authentication
# ------------------------------------------------------------
# Generate a strong secret: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ------------------------------------------------------------
# Application URLs
# ------------------------------------------------------------
# Public URL where the web app is accessible
APP_URL=http://129.151.177.10:3000

# Public URL where the API is accessible (used by the browser)
API_URL=http://129.151.177.10:4000

# CORS origin — must match the web app URL
CORS_ORIGIN=http://129.151.177.10:3000

# NEXT_PUBLIC_API_URL is built into the web app at build time.
# This is the URL the browser uses to reach the API.
NEXT_PUBLIC_API_URL=http://129.151.177.10:4000/api/v1

# ------------------------------------------------------------
# Ports (host-side)
# ------------------------------------------------------------
API_PORT=4000
WEB_PORT=3000

# ------------------------------------------------------------
# AI / Ollama
# ------------------------------------------------------------
AI_PROVIDER=ollama
OLLAMA_MODEL=llama3

# Ollama URL is internal Docker network: http://ollama:11434
# No need to set this unless running outside Docker.

# ------------------------------------------------------------
# Email (SMTP) — optional
# ------------------------------------------------------------
# Required for sending invitation emails.
# Get free SMTP at https://mailtrap.io or use your own.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@houseos.app

# ------------------------------------------------------------
# OAuth — optional
# ------------------------------------------------------------
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# MICROSOFT_TENANT_ID=common
